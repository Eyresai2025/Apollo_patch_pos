LIVE_SKU_DIGITS=3
# =========================================================
# APPLICATION OK BIT
# Application -> PLC
# Confirmed working:
# APP_OK = DB74.DBX0.0 BOOL
# =========================================================
APP_OK_DB=74
APP_OK_BYTE=0
APP_OK_BIT=0
 
 
# =========================================================
# ACCEPT / REJECT RESULT BITS
# Application -> PLC
# =========================================================
PLC_ACCEPT_DB=100
PLC_ACCEPT_BYTE=0
PLC_ACCEPT_BIT=2
 
PLC_REJECT_DB=100
PLC_REJECT_BYTE=0
PLC_REJECT_BIT=3
 
PLC_RESULT_PULSE_MS=300
# =========================================================
# TEST MODE REQUIREMENTS
# =========================================================
REQUIRE_LIGHTS=True
REQUIRE_LASER=False
 
 
# =========================================================
# LIGHTWEIGHT LIVE COMPONENT HEALTH MONITOR
# =========================================================
HEALTH_MONITOR_INTERVAL_MS=3000
STORAGE_MIN_FREE_GB=20
 
 
# =========================================================
# MACHINE MODE
# PLC -> Application
#
# DB74.DBW74 INT
#
# 0 = UNKNOWN
# 1 = MANUAL
# 2 = AUTO
# 3 = FAULT
# 4 = TEACHING
# =========================================================
PLC_MODE_DB=74
PLC_MODE_BYTE=74
PLC_MODE_SIZE=2
PLC_MODE_TYPE=INT


# =========================================================
# GUI TO PLC COMMAND BUTTONS
# =========================================================
PLC_GUI_COMMAND_PULSE_SEC=0.5

PLC_AUTO_START_GUI_DB=74
PLC_AUTO_START_GUI_BYTE=87
PLC_AUTO_START_GUI_BIT=1

PLC_ALL_SERVO_RESET_GUI_DB=74
PLC_ALL_SERVO_RESET_GUI_BYTE=87
PLC_ALL_SERVO_RESET_GUI_BIT=2


CAPTURE_TRIGGER_DB=74
NEW_SKU_CAPTURE_TRIGGER_BYTE=0
NEW_SKU_CAPTURE_TRIGGER_BIT=3
NEW_SKU_CAPTURE_POLL_DELAY_SEC=0.02
 
# =========================================================
# AXIS STATUS PAGE
# =========================================================
AXIS_STATUS_REFRESH_MS=1000
 
# =========================================================
# PLC ACTIVE RUNNING RECIPE
# PLC -> Application
#
# PLC team confirmed:
# ACTIVE RECIPE = INT at DB74.DBW78
# =========================================================
PLC_ACTIVE_RECIPE_DB=74
PLC_ACTIVE_RECIPE_BYTE=78
PLC_ACTIVE_RECIPE_SIZE=2
PLC_ACTIVE_RECIPE_TYPE=INT
 
 
# =========================================================
# DB75 ACTIVE / RUNNING SERVO RECIPE VALUES
# PLC -> Application
#
# DB75.DBD0 to DB75.DBD284 are current/running machine recipe values.
# Application only READS these values for Axis Status comparison.
#
# IMPORTANT:
# DB75.DBW288 is NOT active SKU / active recipe read tag.
# DB75.DBW288 is RECIPE NUMBER ENTRY / WRITE tag.
# =========================================================
ACTIVE_RECIPE_DB=75
ACTIVE_RECIPE_VALUE_TYPE=REAL
ACTIVE_RECIPE_AXIS_BLOCK_BYTES=24
ACTIVE_RECIPE_WORK1_OFFSET=4
ACTIVE_RECIPE_WORK2_OFFSET=8
ACTIVE_RECIPE_TOLERANCE=1.0
 
 
# =========================================================
# PLC RECIPE NAME WRITE
# Tyre Name / Recipe Name -> PLC
#
# PLC tag:
# RECIPE Name STRING at DB53.DBX0.0
#
# For Siemens STRING[n]:
# byte 0 = max length
# byte 1 = actual length
# byte 2 onward = text
# =========================================================
RECIPE_NAME_WRITE_ENABLED=True
RECIPE_NAME_WRITE_DB=53
RECIPE_NAME_WRITE_BYTE=0
RECIPE_NAME_WRITE_MAX_LEN=50
# =========================================================
# PLC RECIPE NUMBER ENTRY TAG
# Application -> PLC
#
# PLC team confirmed:
# RECEIPE NUMBER = INT at DB75.DBW288
#
# This is written when New SKU / Recipe Management loads recipe to machine.
# This is NOT used by Axis Status as active SKU.
# =========================================================
RECIPE_NUMBER_WRITE_DB=75
RECIPE_NUMBER_WRITE_BYTE=288
RECIPE_NUMBER_WRITE_TYPE=INT
 
 
# =========================================================
# NEW SKU / RECIPE CONFIG
# =========================================================
NEW_SKU_DEFAULT_IMAGE_COUNT_PER_ZONE=20
NEW_SKU_DEFAULT_TRAIN_GOOD_COUNT=10
NEW_SKU_DEFAULT_ZONE_COUNT=5
 
RECIPE_BACKUP_DIR=media/recipe_backups
 
 
