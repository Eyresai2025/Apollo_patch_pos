 # =========================================================
# LUCID CAMERA ROLE SERIAL MAPPING
# Final PLC-software shared inner/bead flow
# 250500042 is opened ONCE and used for both:
#   innerwall -> MAIN group DB74.DBX0.3
#   bead      -> BEAD group DB74.DBX86.0
# =========================================================
CAM_SIDEWALL1_SERIAL=254901432
CAM_SIDEWALL2_SERIAL=254901428
CAM_INNERWALL_SERIAL=250500042
CAM_TREAD_SERIAL=254901430
CAM_BEAD_SERIAL=250500042

CAM_SHARED_INNER_BEAD=True

CAM_SIDEWALL1_ENABLED=True
CAM_SIDEWALL2_ENABLED=True
CAM_INNERWALL_ENABLED=True
CAM_TREAD_ENABLED=True
CAM_BEAD_ENABLED=True

# =========================================================
# LIVE CAPTURE TRIGGER MODE
# PLC software trigger:
# Main cameras wait DB74.DBX0.3
# Bead waits DB74.DBX86.0
# Python executes TriggerSoftware after PLC bit HIGH
# =========================================================
CAM_TRIGGER_MODE=plc_software
CAM_TRIGGER_SELECTOR=AcquisitionStart
CAM_TRIGGER_SOURCE=Software
CAM_TRIGGER_ACTIVATION=RisingEdge

LIVE_MAIN_TRIGGER_DB=74
LIVE_MAIN_TRIGGER_BYTE=0
LIVE_MAIN_TRIGGER_BIT=3

LIVE_BEAD_TRIGGER_DB=74
LIVE_BEAD_TRIGGER_BYTE=86
LIVE_BEAD_TRIGGER_BIT=0

# Final standalone used 0.005 for faster bead edge catch.
LIVE_PLC_POLL_DELAY_SEC=0.005
LIVE_PLC_HIGH_LOG_EVERY_SEC=1.0

# =========================================================
# CAPTURE / STREAM RESET SETTINGS
# =========================================================
CAM_BUFFER_TIMEOUT_MS=300000
CAM_FLUSH_COUNT=16

CAM_AFTER_TRIGGER_DELAY_SEC=0.02
CAM_AFTER_ACQ_STOP_DELAY_SEC=0.15
CAM_AFTER_STOP_STREAM_DELAY_SEC=0.20
CAM_AFTER_START_STREAM_DELAY_SEC=0.25

# Keep False to match your final standalone.
# If bead delay is still high, test True later.
CAM_FAST_RESET_SHARED_CAMERA=False
CAM_FAST_RESET_SLEEP_SEC=0.05
CAM_FAST_FLUSH_COUNT=32
CAM_FAST_FLUSH_TIMEOUT_MS=2
CAM_MAX_ALLOWED_BEAD_TRIGGER_DELAY_MS=75.0
CAM_VERBOSE_CONFIG_LOGS=False
CAM_PARALLEL_CAPTURE=True

# =========================================================
# GIGE STREAM SETTINGS
# =========================================================
CAM_PACKET_SIZE=9000
CAM_PACKET_DELAY=1000



# =========================================================
# INSPECTION MONGODB SCHEMA + GRIDFS
# =========================================================
INSPECTION_COLLECTION=TYRE DETAILS
INSPECTION_SCHEMA_VERSION=2.1
INSPECTION_CREATE_INDEXES=True
INSPECTION_KEEP_LEGACY_FIELDS=True
INSPECTION_SAVE_AI_STAGE=True
INSPECTION_FINALIZE_AFTER_PLC=True

INSPECTION_GRIDFS_ENABLED=True
INSPECTION_GRIDFS_UPLOAD_INPUTS=True
INSPECTION_GRIDFS_UPLOAD_OUTPUTS=True
INSPECTION_GRIDFS_KEEP_LOCAL_PATHS=True
INSPECTION_GRIDFS_REUSE_EXISTING=True

INSPECTION_INPUT_GRIDFS_BUCKET=input_images_fs
INSPECTION_OUTPUT_GRIDFS_BUCKET=output_images_fs
INSPECTION_INPUT_METADATA_COLLECTION=Input Images
INSPECTION_OUTPUT_METADATA_COLLECTION=Output Images

# =========================================================
# INSPECTION OFFLINE OUTBOX + AUTOMATIC MONGODB SYNC V3
# =========================================================
INSPECTION_OFFLINE_OUTBOX_ENABLED=True
INSPECTION_OUTBOX_PATH=data/inspection/inspection_outbox.db

INSPECTION_SYNC_ENABLED=True
INSPECTION_SYNC_INTERVAL_SEC=30
INSPECTION_SYNC_BATCH_SIZE=10
INSPECTION_SYNC_MAX_RETRIES=20
INSPECTION_SYNC_RETRY_BACKOFF_SEC=30
