# Apollo VIT deployment configuration template.
# Copy this file to .env and fill values for the target IPC.

APP_VERSION=v1.0
BUILD_NUMBER=
BUILD_DATE=
DEPLOYMENT=False

DATABASE_URL=mongodb://localhost:27017/
DATABASE_NAME=EyresQC_Apollo
GRIDFS_BUCKET=fs
DB_POOL_SIZE=50
DB_MIN_POOL_SIZE=10
DB_TIMEOUT_MS=5000
DB_CONNECT_TIMEOUT_MS=10000

PLC_IP=192.168.10.1
PLC_TYPE=Siemens S7-1500
PLC_RACK=0
PLC_SLOT=1
PLC_RETRY_COUNT=3
PLC_RETRY_DELAY_SEC=1.0

INFERENCE_DEVICE=cuda
ENABLE_WARMUP=True
WARMUP_ITER=2
INFERENCE_TIMEOUT=30
R_ALIGN_CONC=5
VIT_CONC=5
YOLO_CONC=5

MODEL_DIR=media/weights
CAPTURE_DIR=media/capture
OUTPUT_DIR=media/output
RECIPE_BACKUP_DIR=media/recipe_backups
LOG_DIR=logs

WEIGHT_FILE_Apollo=
WEIGHT_FILE_RE_ONNX=
WEIGHT_FILE_CLASS=
VIT_CHECKPOINT=

HEALTH_MONITOR_INTERVAL_MS=5000
STORAGE_MIN_FREE_GB=10
REQUIRE_LIGHTS=False
REQUIRE_LASER=False

CAM_SIDEWALL1_SERIAL=
CAM_SIDEWALL2_SERIAL=
CAM_INNERWALL_SERIAL=
CAM_TREAD_SERIAL=
CAM_BEAD_SERIAL=
CAM_SHARED_INNER_BEAD=False
CAM_TRIGGER_MODE=plc_software
CAM_PACKET_SIZE=9000
CAM_PACKET_DELAY=1000

# Keep the full machine-specific PLC axis, recipe-target and trigger mappings
# from your approved deployment .env. The central manager exposes all keys,
# including keys not listed in this short template.

# Structured logging
LOG_LEVEL=INFO
LOG_CONSOLE_ENABLED=True
LOG_TEXT_ENABLED=True
LOG_JSON_ENABLED=True
LOG_ERROR_ENABLED=True
LOG_FILE_NAME=app.log
LOG_JSON_FILE_NAME=app.jsonl
LOG_ERROR_FILE_NAME=error.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_REPEAT_WINDOW_SEC=5

# Role-based login and permissions
AUTH_ENABLED=True
AUTH_DB_PATH=data/security/apollo_security.db
AUTH_SESSION_TIMEOUT_MIN=30
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MIN=15
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_PASSWORD_MAX_LENGTH=128
AUTH_REQUIRE_COMPLEX_PASSWORD=True
AUTH_ALLOW_SELF_SIGNUP=False

# PostgreSQL Phase 1 parallel configuration.
# Keep MongoDB DATABASE_URL/DATABASE_NAME until the PostgreSQL migration is complete.
POSTGRES_ENABLED=False
POSTGRES_ADMIN_URL=postgresql://postgres:CHANGE_ME_ADMIN_PASSWORD@127.0.0.1:5432/postgres
POSTGRES_APP_USER=apollo_user
POSTGRES_APP_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB_NAME=eyresqc_apollo
POSTGRES_DATABASE_URL=postgresql://apollo_user:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/eyresqc_apollo
POSTGRES_SCHEMA=apollo
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=8
POSTGRES_POOL_TIMEOUT_SEC=30
POSTGRES_CONNECT_TIMEOUT_SEC=5
POSTGRES_STATEMENT_TIMEOUT_MS=30000
POSTGRES_APPLICATION_NAME=Apollo_VIT_Edge
